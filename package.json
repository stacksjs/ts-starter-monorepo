{
  "name": "ts-charts",
  "type": "module",
  "version": "0.0.0",
  "description": "A complete TypeScript rewrite of D3.js as a Bun-first monorepo.",
  "author": "Chris Breuer <chris@stacksjs.com>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-charts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-charts.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-charts/issues"
  },
  "keywords": [
    "d3",
    "charts",
    "visualization",
    "typescript",
    "bun"
  ],
  "scripts": {
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "test": "TZ=America/Los_Angeles bun test",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "changelog": "bunx --bun logsmith --verbose",
    "changelog:generate": "bunx --bun logsmith --output CHANGELOG.md",
    "release": "bun run changelog:generate && bunx --bun bumpx prompt --recursive",
    "dev:docs": "bunx --bun bunpress dev docs",
    "build:docs": "bunx --bun bunpress build docs",
    "preview:docs": "bunx --bun bunpress preview docs",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "devDependencies": {
    "better-dx": "^0.2.6",
    "bunfig": "^0.15.6",
    "very-happy-dom": "^0.0.9"
  },
  "workspaces": [
    "packages/*"
  ]
}
